# Agent Configuration
AGENT_TEMPERATURE=0.15
AGENT_MARKDOWN=true
AGENT_NAME=ResearchAssistant

# RAG Backend Configuration
RAG_BASE_URL=http://backend-webserver.research-assistant:8080
RAG_SSL_VERIFY=false
RAG_TIMEOUT=60.0

# VastDB Configuration
VASTDB_ENDPOINT=
VASTDB_ACCESS_KEY=
VASTDB_SECRET_KEY=

# API Configuration
API_TITLE=Research Assistant API
API_DESCRIPTION=API for research assistant with RAG backend integration
API_VERSION=1.0.0

# Model Provider: "nvidia" (default, uses OpenAI-compatible API) or "gemini"
MODEL_PROVIDER=nvidia

# OpenAI/NVIDIA Configuration (used when MODEL_PROVIDER=nvidia)
AGENT_OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
AGENT_OPENAI_MODEL_ID=meta/llama-3.3-70b-instruct
AGENT_OPENAI_API_KEY=

# Google Gemini Configuration (used when MODEL_PROVIDER=gemini)
GEMINI_MODEL_ID=gemini-2.5-pro
GOOGLE_API_KEY=

# Azure AD Configuration (optional)
AUTH__AZURE__CLIENTID=
AUTH__AZURE__CLIENTSECRET=
AUTH__AZURE__NEXTAUTHSECRET=
AUTH__AZURE__AUTHORIZATIONENDPOINT=
AUTH__AZURE__TOKENENDPOINT=
AUTH__AZURE__ISSUERENDPOINT=
AUTH__AZURE__JWKSENDPOINT=
AUTH__AZURE__REDIRECTURI=
AUTH__AZURE__NEXTAUTHURL=
